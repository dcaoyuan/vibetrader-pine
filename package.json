{
  "name": "my-transpiler",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "build:parser && vite",
    "build:parser": "peggy --plugin ts-pegjs --format es -o src/parser.ts src/grammar/pine.pegjs"
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "typescript": "~5.9.3",
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "dependencies": {
    "peggy": "^3.0.2",
    "ts-pegjs": "^4.2.1"
  }
}
